{
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "destinations": ["sentry-logs"],
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "destinations": ["sentry-traces"],
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
